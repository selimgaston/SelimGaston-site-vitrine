{
  "name": "selimgaston-site-vitrine",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "dev:node22": "npx -y node@22 node_modules/next/dist/bin/next dev",
    "build": "next build",
    "build:node22": "npx -y node@22 node_modules/next/dist/bin/next build",
    "start": "next start",
    "deploy": "npm run build && npx wrangler pages deploy out --project-name selimgaston-site-vitrine",
    "deploy:node22": "npm run build:node22 && npx -y node@22 node_modules/wrangler/bin/wrangler.js pages deploy out --project-name selimgaston-site-vitrine"
  },
  "dependencies": {
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "overrides": {
    "postcss": "8.5.10"
  },
  "devDependencies": {
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "typescript": "6.0.3",
    "wrangler": "^4.107.0"
  }
}
